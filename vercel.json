{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "data/**",
        "worldcup_channels.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/api/index.js"
    }
  ]
}
